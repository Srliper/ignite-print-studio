# =============================================================================
# SUPABASE — marque Production + Preview na Vercel
# =============================================================================
SUPABASE_URL=https://SEU_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sua_chave_anon
VITE_SUPABASE_URL=https://SEU_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_chave_anon

# =============================================================================
# GOOGLE OAUTH (Auth.js)
# =============================================================================
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-seu_secret

# Aceita AUTH_* (local) ou NEXTAUTH_* (Vercel / legado)
AUTH_SECRET=gere_com_node_crypto_randomBytes_32_base64
AUTH_URL=http://localhost:5173

# Produção (Vercel) — use NEXTAUTH_* ou AUTH_* (código aceita ambos):
# NEXTAUTH_SECRET=mesmo_valor_de_AUTH_SECRET
# NEXTAUTH_URL=https://ignite-print-studio.vercel.app

# Google Console → Authorized redirect URIs:
#   http://localhost:5173/oauth/callback/google
#   https://ignite-print-studio.vercel.app/oauth/callback/google
