# Supabase
SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Google OAuth (Auth.js) — obrigatório para login com Google
# Gere o secret com: openssl rand -base64 32
GOOGLE_CLIENT_ID=seu_client_id
GOOGLE_CLIENT_SECRET=seu_client_secret

# Auth.js aceita AUTH_* ou NEXTAUTH_* (comum na Vercel)
AUTH_SECRET=string_aleatoria_segura
# NEXTAUTH_SECRET=string_aleatoria_segura

# IMPORTANTE: pode ser só o domínio — o código adiciona /oauth automaticamente
AUTH_URL=http://localhost:5173
# NEXTAUTH_URL=http://localhost:5173

# Produção (Vercel):
# AUTH_URL=https://ignite-print-studio.vercel.app
# NEXTAUTH_URL=https://ignite-print-studio.vercel.app
